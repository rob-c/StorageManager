<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="MountTool.MainWindow"
        Title="PPE Storage"
        Icon="/Assets/logo.png"
        Background="{DynamicResource AppWindowBackground}"
        Width="440" SizeToContent="Height"
        CanResize="False"
        WindowStartupLocation="CenterScreen">

  <Window.Styles>
    <!-- Secondary actions: the standard button chrome, just smaller. -->
    <Style Selector="Button.tool">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Padding" Value="12,5" />
      <Setter Property="MinWidth" Value="92" />
      <Setter Property="Margin" Value="0,0,8,8" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
    </Style>
  </Window.Styles>

  <StackPanel Margin="28,24,28,24" Spacing="6">

    <StackPanel Orientation="Horizontal" Spacing="14" Margin="0,0,0,14">
      <Image Source="/Assets/logo.png" Width="44" Height="44" VerticalAlignment="Center" />
      <StackPanel VerticalAlignment="Center" Spacing="2">
        <TextBlock Text="PPE Storage" FontSize="18" FontWeight="SemiBold" />
        <TextBlock Text="Connect to the university datastore"
                   FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
      </StackPanel>
    </StackPanel>

    <TextBlock Text="Username" FontSize="12"
               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
    <TextBox x:Name="UsernameBox" Watermark="university username" Margin="0,0,0,8" />

    <TextBlock Text="Password" FontSize="12"
               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
    <TextBox x:Name="PasswordBox" PasswordChar="●" Watermark="university password" Margin="0,0,0,8" />

    <TextBlock Text="Remote host" FontSize="12"
               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
    <ComboBox x:Name="HostBox" HorizontalAlignment="Stretch" Margin="0,0,0,8" />

    <TextBlock Text="Remote folder" FontSize="12"
               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
    <ComboBox x:Name="RemoteBox" HorizontalAlignment="Stretch" Margin="0,0,0,8" />

    <TextBlock Text="Mount location" FontSize="12"
               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
    <TextBox x:Name="TargetBox" />
    <ComboBox x:Name="DriveBox" IsVisible="False" HorizontalAlignment="Stretch" />

    <CheckBox x:Name="ReadWriteCheck" Margin="0,10,0,0"
              Content="Allow read-write access (writable)"
              ToolTip.Tip="Off by default for safety: the mount is read-only so files can't be changed or deleted by accident. Tick this to enable writing." />

    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,14,0,0">
      <Ellipse x:Name="StatusDot" Width="9" Height="9" VerticalAlignment="Center"
               Fill="{DynamicResource TextFillColorTertiaryBrush}" />
      <TextBlock x:Name="StatusLabel" Text="Not connected." FontSize="12"
                 VerticalAlignment="Center"
                 Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
    </StackPanel>

    <WrapPanel Margin="0,12,0,0">
      <WrapPanel.Styles>
        <Style Selector="Button">
          <Setter Property="MinWidth" Value="118" />
          <Setter Property="Margin" Value="0,0,10,8" />
        </Style>
      </WrapPanel.Styles>
      <Button x:Name="ConnectButton" Content="Connect"
              Classes="accent" IsDefault="True" Click="OnConnect" />
      <Button x:Name="ReconnectButton" Content="Reconnect"
              IsVisible="False" Click="OnReconnect" />
      <Button x:Name="OpenButton" Content="Open" IsEnabled="False" Click="OnOpen" />
      <Button x:Name="DisconnectButton" Content="Disconnect" IsEnabled="False" Click="OnDisconnect" />
    </WrapPanel>

    <WrapPanel Margin="0,12,0,0">
      <Button x:Name="DoctorButton" Classes="tool" Content="SSH Doctor…" Click="OnOpenDoctor" />
      <Button x:Name="VsCodeButton" Classes="tool" Content="VS Code…" Click="OnOpenVsCode" />
      <Button x:Name="StatusButton" Classes="tool" Content="Status…" Click="OnOpenStatus" />
      <Button x:Name="NewConnectionButton" Classes="tool" Content="New connection" Click="OnNewConnection" />
    </WrapPanel>

    <TextBlock x:Name="SupportLabel" FontSize="11" Margin="0,14,0,0" TextWrapping="Wrap"
               Foreground="{DynamicResource TextFillColorTertiaryBrush}" />

  </StackPanel>
</Window>
